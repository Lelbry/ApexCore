#!/bin/sh
# Pre-removal hook для ApexCore.
# Останавливаем фоновые процессы (если есть) до удаления venv.

set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Если запущен webui — найти PID и попросить остановиться.
        # Wizard не оставляет демонов, но `apexcore webui` запущенный
        # пользователем мог остаться.
        pattern='apexcore.*webui'
        if pgrep -f "$pattern" >/dev/null 2>&1; then
            echo "Останавливаю запущенные процессы ($pattern)..."
            pkill -TERM -f "$pattern" >/dev/null 2>&1 || true
            sleep 1
            pkill -KILL -f "$pattern" >/dev/null 2>&1 || true
        fi
        ;;
esac

#DEBHELPER#
exit 0
