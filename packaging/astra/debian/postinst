#!/bin/sh
# Постустановочный скрипт ApexCore.
# Не делает destructive автонастроек. Только:
#   - обновляет кэш иконок (gtk-update-icon-cache)
#   - проверяет окружение (Python ≥ 3.11)
#   - мигрирует данные из /opt/benchkit/ → /opt/apexcore/ (v0.8.x → v0.9.0)
#     и из user-data dirs ~/.local/share/benchkit/ → ~/.local/share/apexcore/
#   - печатает приглашение на запуск `apexcore setup` для wizard'а
#
# Реальная пост-установочная настройка (sensors-detect, setcap, BLAS probe)
# выполняется в wizard'е через /ws/setup. Это позволяет пользователю явно
# увидеть и подтвердить каждый шаг.

set -e

migrate_user_dirs() {
    # Перенести содержимое ~/.local/share/benchkit → ~/.local/share/apexcore
    # для каждого реального пользователя в /home/. Не падаем при ошибках.
    # Backward-compat для upgrade с v0.8.x; удалить в v0.10.0.
    for home in /home/* /root; do
        [ -d "$home" ] || continue
        legacy_dir="$home/.local/share/benchkit"
        new_dir="$home/.local/share/apexcore"
        if [ -d "$legacy_dir" ] && [ ! -e "$legacy_dir/.migrated_to_apexcore" ]; then
            if [ ! -d "$new_dir" ] || [ -z "$(ls -A "$new_dir" 2>/dev/null)" ]; then
                mkdir -p "$new_dir"
                # Копируем (не mv) чтобы не сломать существующие открытые файлы;
                # apexcore-код тоже сделает миграцию при первом запуске.
                cp -a "$legacy_dir"/. "$new_dir"/ 2>/dev/null || true
                echo "Перенесено в $new_dir" > "$legacy_dir/.migrated_to_apexcore"
                # Восстанавливаем владельца — cp под root может сменить uid.
                owner=$(stat -c '%U:%G' "$home" 2>/dev/null || echo "")
                if [ -n "$owner" ]; then
                    chown -R "$owner" "$new_dir" 2>/dev/null || true
                fi
                echo "[apexcore] Перенесены данные пользователя: $legacy_dir → $new_dir"
            fi
        fi
    done
}

case "$1" in
    configure)
        # ── Backward-compat миграция /opt/benchkit/ → /opt/apexcore/ ──
        # /opt/benchkit/ остаётся (это venv от старого .deb-пакета, dpkg
        # снимет его автоматически через Conflicts/Replaces). Но user-data
        # в ~/.local/share/benchkit/ — отдельная история, мигрируем явно.
        migrate_user_dirs || true

        # Обновить кэш иконок (если есть gtk-update-icon-cache).
        if command -v gtk-update-icon-cache >/dev/null 2>&1; then
            gtk-update-icon-cache -q /usr/share/icons/hicolor/ 2>/dev/null || true
        fi

        # Проверка бандл-питона: apexcore поставляется со СВОИМ CPython в
        # /opt/apexcore/.venv (системный python3 не используется вовсе).
        # Убеждаемся, что интерпретатор запускается на этой машине (могут быть
        # очень старые glibc).
        if [ -x /opt/apexcore/.venv/bin/python3 ]; then
            if ! /opt/apexcore/.venv/bin/python3 --version >/dev/null 2>&1; then
                echo "[!] Внимание: бандл-питон /opt/apexcore/.venv/bin/python3 не запускается"
                echo "    (возможна слишком старая glibc). Сообщите об ОС/ядре в issue."
            fi
        else
            echo "[!] Внимание: /opt/apexcore/.venv/bin/python3 не найден — переустановите apexcore."
        fi

        cat <<'EOF'

======================================================================
  ApexCore установлен в /opt/apexcore/

  Для завершения настройки запустите wizard в браузере:

      apexcore setup

  Wizard проведёт через:
    - проверку драйверов (NVIDIA / AMD)
    - проверку BLAS (OpenBLAS) для numpy/scipy
    - установку capability'ов для smartctl и dmidecode (через pkexec)
    - активацию lm-sensors (sensors-detect, через pkexec)
    - первый запуск Web UI на http://127.0.0.1:8765

  Документация: https://github.com/Lelbry/apexcore
======================================================================

EOF
        ;;
esac

#DEBHELPER#
exit 0
